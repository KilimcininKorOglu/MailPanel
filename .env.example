## Backend: ldap or mysql
MAILPANEL_BACKEND=ldap

## General
MAILPANEL_SECRET_KEY=change-me-to-a-random-string

## LDAP Settings (required when MAILPANEL_BACKEND=ldap)
MAILPANEL_LDAP_URI=ldap://192.168.2.1
MAILPANEL_LDAP_ROOT_DN=dc=example,dc=com
MAILPANEL_LDAP_USER=postmaster@example.com
MAILPANEL_LDAP_PASSWORD=password
# MAILPANEL_LDAP_TLS_VERIFY=false

## MySQL Settings (required when MAILPANEL_BACKEND=mysql)
# MAILPANEL_MYSQL_HOST=127.0.0.1
# MAILPANEL_MYSQL_PORT=3306
# MAILPANEL_MYSQL_DATABASE=vmail
# MAILPANEL_MYSQL_USER=vmailadmin
# MAILPANEL_MYSQL_PASSWORD=password
# MAILPANEL_VMAIL_PATH=/var/vmail
# MAILPANEL_STORAGE_NODE=vmail1

## Password Settings
# MAILPANEL_PASSWORD_MIN_LENGTH=8
# MAILPANEL_PASSWORD_INCLUDES_SPECIAL_CHARS=true
# MAILPANEL_PASSWORD_INCLUDES_NUMBERS=true
# MAILPANEL_PASSWORD_INCLUDES_LOWERCASE=true
# MAILPANEL_PASSWORD_INCLUDES_UPPERCASE=true
# MAILPANEL_PASSWORD_HASHES_USE_PREFIXED_SCHEME=true
# MAILPANEL_PASSWORD_DEFAULT_SCHEME=SSHA512

## Pagination
# MAILPANEL_PAGINATION_PER_PAGE=50

## Branding
# MAILPANEL_BRAND_NAME=MailPanel
# MAILPANEL_BRAND_LOGO_URL=/static/logo-iredmail.png
# MAILPANEL_BRAND_FOOTER_TEXT=
# MAILPANEL_BRAND_PRIMARY_COLOR=

## Password Change
# MAILPANEL_REQUIRE_OLD_PASSWORD_ON_CHANGE=false

## Session Security
# MAILPANEL_SESSION_TIMEOUT=1800
# MAILPANEL_ALLOWED_IP_RANGES=
# MAILPANEL_SESSION_VALIDATE_IP=false

## iRedAdmin Database (optional, for activity logging)
# MAILPANEL_IREDADMIN_DB_HOST=127.0.0.1
# MAILPANEL_IREDADMIN_DB_PORT=3306
# MAILPANEL_IREDADMIN_DB_NAME=iredadmin
# MAILPANEL_IREDADMIN_DB_USER=iredadmin
# MAILPANEL_IREDADMIN_DB_PASSWORD=password
# MAILPANEL_ACTIVITY_LOGGING_ENABLED=true

## Amavisd Integration (optional, quarantine + mail log)
# MAILPANEL_AMAVISD_ENABLED=false
# MAILPANEL_AMAVISD_DB_HOST=127.0.0.1
# MAILPANEL_AMAVISD_DB_PORT=3306
# MAILPANEL_AMAVISD_DB_NAME=amavisd
# MAILPANEL_AMAVISD_DB_USER=amavisd
# MAILPANEL_AMAVISD_DB_PASSWORD=password
# MAILPANEL_AMAVISD_REMOVE_QUARANTINED_IN_DAYS=7
# MAILPANEL_AMAVISD_REMOVE_MAILLOG_IN_DAYS=7

## Fail2ban Integration (optional, ban/unban management)
# MAILPANEL_FAIL2BAN_ENABLED=false
# MAILPANEL_FAIL2BAN_SOCKET=
# MAILPANEL_FAIL2BAN_JAILS=dovecot,postfix,postfix-sasl

## iRedAPD Integration (optional, throttle + greylisting)
# MAILPANEL_IREDAPD_ENABLED=false
# MAILPANEL_IREDAPD_DB_HOST=127.0.0.1
# MAILPANEL_IREDAPD_DB_PORT=3306
# MAILPANEL_IREDAPD_DB_NAME=iredapd
# MAILPANEL_IREDAPD_DB_USER=iredapd
# MAILPANEL_IREDAPD_DB_PASSWORD=password
