## Mail data backend: ldap, mysql, or pgsql
MAILPANEL_BACKEND=ldap

## Secret key used for session encryption (change this to a random string)
MAILPANEL_SECRET_KEY=change-me-to-a-random-string

## LDAP Settings (required when MAILPANEL_BACKEND=ldap)

# LDAP server URI (ldap:// for plain, ldaps:// for TLS)
MAILPANEL_LDAP_URI=ldap://192.168.2.1

# Base DN of the LDAP directory tree (e.g. dc=example,dc=com)
MAILPANEL_LDAP_ROOT_DN=dc=example,dc=com

# LDAP bind user (email or DN used to authenticate)
MAILPANEL_LDAP_USER=postmaster@example.com

# LDAP bind password
MAILPANEL_LDAP_PASSWORD=password

# Verify TLS certificate when connecting to LDAP server
# MAILPANEL_LDAP_TLS_VERIFY=false

## MySQL/MariaDB Settings (required when MAILPANEL_BACKEND=mysql)

# MySQL server hostname or IP address
# MAILPANEL_MYSQL_HOST=127.0.0.1

# MySQL server port
# MAILPANEL_MYSQL_PORT=3306

# Name of the vmail database created by iRedMail
# MAILPANEL_MYSQL_DATABASE=vmail

# Database user with read-write access to the vmail database
# MAILPANEL_MYSQL_USER=vmailadmin

# Database user password
# MAILPANEL_MYSQL_PASSWORD=password

# Base path for mail storage on the filesystem
# MAILPANEL_VMAIL_PATH=/var/vmail

## PostgreSQL Settings (required when MAILPANEL_BACKEND=pgsql)

# PostgreSQL server hostname or IP address
# MAILPANEL_PGSQL_HOST=127.0.0.1

# PostgreSQL server port
# MAILPANEL_PGSQL_PORT=5432

# Name of the vmail database created by iRedMail
# MAILPANEL_PGSQL_DATABASE=vmail

# Database user with read-write access to the vmail database
# MAILPANEL_PGSQL_USER=vmailadmin

# Database user password
# MAILPANEL_PGSQL_PASSWORD=password

# Storage node name for mailbox directory structure (iRedMail default: vmail1)
# MAILPANEL_STORAGE_NODE=vmail1

## Password Policy

# Minimum required password length
# MAILPANEL_PASSWORD_MIN_LENGTH=8

# Require at least one special character ($@#%!^&* etc.)
# MAILPANEL_PASSWORD_INCLUDES_SPECIAL_CHARS=true

# Require at least one digit (0-9)
# MAILPANEL_PASSWORD_INCLUDES_NUMBERS=true

# Require at least one lowercase letter (a-z)
# MAILPANEL_PASSWORD_INCLUDES_LOWERCASE=true

# Require at least one uppercase letter (A-Z)
# MAILPANEL_PASSWORD_INCLUDES_UPPERCASE=true

# Prefix password hashes with scheme identifier (e.g. {SSHA512})
# MAILPANEL_PASSWORD_HASHES_USE_PREFIXED_SCHEME=true

# Default hashing scheme: SSHA512, BCRYPT, SHA512, SSHA, MD5, PLAIN-MD5, CRAM-MD5, NTLM, PLAIN
# MAILPANEL_PASSWORD_DEFAULT_SCHEME=SSHA512

## Pagination

# Number of items displayed per page on list views
# MAILPANEL_PAGINATION_PER_PAGE=50

## Branding

# Application name shown in the UI title and navigation bar
# MAILPANEL_BRAND_NAME=MailPanel

# URL of the logo image displayed in the navigation bar
# MAILPANEL_BRAND_LOGO_URL=/static/logo-iredmail.png

# Custom text displayed in the page footer
# MAILPANEL_BRAND_FOOTER_TEXT=

# CSS color value to override the default primary color (e.g. #1a73e8)
# MAILPANEL_BRAND_PRIMARY_COLOR=

## Password Change

# Require users to enter their current password before setting a new one
# MAILPANEL_REQUIRE_OLD_PASSWORD_ON_CHANGE=false

## Session Security

# Session timeout in seconds (default: 1800 = 30 minutes)
# MAILPANEL_SESSION_TIMEOUT=1800

# Comma-separated CIDR ranges allowed to access the panel (empty = allow all)
# MAILPANEL_ALLOWED_IP_RANGES=

# Invalidate session if the client IP address changes mid-session
# MAILPANEL_SESSION_VALIDATE_IP=false

## Update Checking

# Check GitHub Releases API daily for new MailPanel versions (shown on dashboard)
# MAILPANEL_CHECK_UPDATES=true

## iRedAdmin Database (optional, enables activity logging)

# Hostname of the iRedAdmin database server
# MAILPANEL_IREDADMIN_DB_HOST=127.0.0.1

# Port of the iRedAdmin database server (3306 for MySQL, 5432 for PostgreSQL)
# MAILPANEL_IREDADMIN_DB_PORT=3306

# Name of the iRedAdmin database
# MAILPANEL_IREDADMIN_DB_NAME=iredadmin

# Database user for the iRedAdmin database
# MAILPANEL_IREDADMIN_DB_USER=iredadmin

# Database password for the iRedAdmin database
# MAILPANEL_IREDADMIN_DB_PASSWORD=password

# Enable or disable admin activity logging to the iRedAdmin database
# MAILPANEL_ACTIVITY_LOGGING_ENABLED=true

## Amavisd Integration (optional, enables quarantine viewer and mail log)

# Enable Amavisd quarantine and mail log features
# MAILPANEL_AMAVISD_ENABLED=false

# Hostname of the Amavisd database server
# MAILPANEL_AMAVISD_DB_HOST=127.0.0.1

# Port of the Amavisd database server
# MAILPANEL_AMAVISD_DB_PORT=3306

# Name of the Amavisd database
# MAILPANEL_AMAVISD_DB_NAME=amavisd

# Database user for the Amavisd database
# MAILPANEL_AMAVISD_DB_USER=amavisd

# Database password for the Amavisd database
# MAILPANEL_AMAVISD_DB_PASSWORD=password

# Number of days to keep quarantined messages before automatic cleanup
# MAILPANEL_AMAVISD_REMOVE_QUARANTINED_IN_DAYS=7

# Number of days to keep mail log entries before automatic cleanup
# MAILPANEL_AMAVISD_REMOVE_MAILLOG_IN_DAYS=7

## Fail2ban Integration (optional, enables ban/unban management)

# Enable Fail2ban jail status and ban/unban features
# MAILPANEL_FAIL2BAN_ENABLED=false

# Custom path to the fail2ban-client socket (leave empty for default)
# MAILPANEL_FAIL2BAN_SOCKET=

# Comma-separated list of Fail2ban jail names to monitor
# MAILPANEL_FAIL2BAN_JAILS=dovecot,postfix,postfix-sasl

## iRedAPD Integration (optional, enables throttle and greylisting management)

# Enable iRedAPD throttle and greylisting features
# MAILPANEL_IREDAPD_ENABLED=false

# Hostname of the iRedAPD database server
# MAILPANEL_IREDAPD_DB_HOST=127.0.0.1

# Port of the iRedAPD database server
# MAILPANEL_IREDAPD_DB_PORT=3306

# Name of the iRedAPD database
# MAILPANEL_IREDAPD_DB_NAME=iredapd

# Database user for the iRedAPD database
# MAILPANEL_IREDAPD_DB_USER=iredapd

# Database password for the iRedAPD database
# MAILPANEL_IREDAPD_DB_PASSWORD=password
