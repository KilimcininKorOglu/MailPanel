{
    "name": "kilimcininkoroglu/mailpanel",
    "version": "0.9.0",
    "description": "Lightweight PHP admin panel for managing iRedMail users and domains via LDAP or MySQL",
    "type": "project",
    "license": "Unlicense",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "suggest": {
        "ext-ldap": "Required for LDAP backend",
        "ext-pdo": "Required for MySQL backend",
        "ext-pdo_mysql": "Required for MySQL backend"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
